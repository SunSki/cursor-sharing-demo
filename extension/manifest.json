{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.1.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": ["storage"],
  "host_permissions": ["https://cursor-sharing-demo.onrender.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_actionTitle__"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/socket.io.min.js", "lib/livecursors.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
