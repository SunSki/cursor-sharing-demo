{
  "manifest_version": 3,
  "name": "LiveCursors — 同じページのカーソルを共有",
  "version": "0.1.0",
  "description": "拡張機能を入れた人同士が同じURLを開いているとき、お互いのカーソルをリアルタイムで表示します。",
  "permissions": ["storage"],
  "host_permissions": ["https://cursor-sharing-demo.onrender.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LiveCursors"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/socket.io.min.js", "lib/livecursors.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
